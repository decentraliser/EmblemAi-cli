{
  "name": "@emblemvault/agentwallet",
  "version": "3.2.0",
  "description": "CLI for EmblemVault Hustle AI - autonomous crypto wallet management with browser auth, streaming, and plugins",
  "main": "emblemai.js",
  "type": "module",
  "bin": {
    "emblemai": "emblemai.js"
  },
  "scripts": {
    "reset": "node emblemai.js --reset",
    "simple": "node emblemai.js --simple",
    "start": "node emblemai.js",
    "test:coverage": "c8 --reporter=text --reporter=lcov --reports-dir coverage node --test",
    "test": "node --test",
    "typecheck:watch": "tsc --project tsconfig.json --watch --preserveWatchOutput",
    "typecheck": "tsc --project tsconfig.json"
  },
  "devDependencies": {
    "@types/node": "^24.0.0",
    "c8": "^11.0.0",
    "typescript": "^5.7.0"
  },
  "dependencies": {
    "@dotenvx/dotenvx": "^1.52.0",
    "@emblemvault/auth-sdk": "^2.3.18",
    "@x402/core": "^2.3.1",
    "@x402/evm": "^2.3.1",
    "@x402/svm": "^2.3.0",
    "blessed": "^0.1.81",
    "blessed-contrib": "^4.11.0",
    "chalk": "^5.3.0",
    "dotenv": "^16.3.1",
    "hustle-incognito": "^1.1.0"
  },
  "keywords": [
    "ai",
    "crypto",
    "hustle",
    "emblem",
    "agent",
    "wallet",
    "solana",
    "ethereum",
    "defi",
    "trading",
    "openclaw",
    "tui"
  ],
  "author": "EmblemVault",
  "license": "MIT",
  "repository": {
    "type": "git",
    "url": "git+https://github.com/EmblemCompany/EmblemAi-AgentWallet.git"
  },
  "homepage": "https://emblemvault.dev",
  "engines": {
    "node": ">=18.0.0"
  },
  "files": [
    "emblemai.js",
    "src/",
    "docs/",
    "README.md"
  ]
}
